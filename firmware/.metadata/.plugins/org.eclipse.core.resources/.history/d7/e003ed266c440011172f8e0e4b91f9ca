#pragma once
#include "main.h"			// contains HAL-Definitions
#include "FreeRTOS.h"
#include "semphr.h"

namespace EVA {

class SSD1306 {

public:

	/**
	* @brief Constructor
	* @param i2cHandle Pointer to the HAL I2C handle
	* @param devAddress The I2C address of the device (e.g., 0x3C << 1)
	*/
	SSD1306 (I2C_HandleTypeDef* i2cHandle, uint8_t devAddress);

	/**
	* @brief Initializes the display hardware with default settings.
	*/
	void init();

	/**
	* @brief Sends a single command to the display. Thread-safe.
	* @param command The command byte to send
	*/
	void writeCommand (uint8_t command);

	/**
	* @brief Sends data buffer to the display. Thread-safe.
	* @param data Pointer to the data array
	* @param size Size of the data buffer
	*/
	void writeData (uint8_t* data, uint16_t size);

	/**
	 * @brief clears the display and removes all data
	 */
	void clear();

	/**
	 * @brief define Pixels to show/draw a sentence or emoji
	 * @param x coordinate from the display
	 * @param y coordinate from the display
	 * @param ON or OFF
	 */
	void drawPixel(int16_t x, int16_t y, bool color);

	/**
	 * @brief Updaes the shown pixels on the display
	 */
	void update();

private:
	I2C_HandleTypeDef* hi2c;
	uint8_t address;
	SemaphoreHandle_t i2cMutex;
	uint8_t buffer[1024];
};


extern SSD1306 display;

}

